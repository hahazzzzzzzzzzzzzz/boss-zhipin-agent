# ===========================================
# BOSS直聘求职Agent 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ===========================================

# --- CodeBuddy SDK 认证 ---
CODEBUDDY_API_KEY=your_api_key_here
CODEBUDDY_AUTH_TOKEN=your_auth_token_here
CODEBUDDY_INTERNET_ENVIRONMENT=
CODEBUDDY_BASE_URL=

# --- 用户画像（可选，会覆盖 agent/config.py 中的默认值）---
USER_NAME=你的姓名
USER_DEGREE=你的学历
USER_SCHOOL=你的学校
USER_GRADUATION_YEAR=2027届

# --- BOSS直聘抓取 Cookie（实际抓取模式必需）---
# 获取方式：
#   1. 浏览器登录 https://www.zhipin.com
#   2. F12 → Network → 搜索 "joblist" → 找到请求 → Headers → Cookie 全部复制
#   3. 粘贴到这里（注意：cookie 含敏感信息，不要提交到 git）
BOSS_COOKIE=
