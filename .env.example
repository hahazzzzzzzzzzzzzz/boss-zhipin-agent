# ===========================================
# BOSS直聘求职Agent 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ===========================================

# --- CodeBuddy SDK 认证 ---
CODEBUDDY_API_KEY=your_api_key_here
CODEBUDDY_AUTH_TOKEN=your_auth_token_here
CODEBUDDY_INTERNET_ENVIRONMENT=
CODEBUDDY_BASE_URL=

# --- 用户画像（可选，会覆盖 agent/config.py 中的默认值）---
USER_NAME=你的姓名
USER_DEGREE=你的学历
USER_SCHOOL=你的学校
USER_GRADUATION_YEAR=2027届
